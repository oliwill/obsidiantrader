# ═══════════════════════════════════════════════════════════════════════════════
# trader-obsidian 环境配置
# ═══════════════════════════════════════════════════════════════════════════════
# 使用说明：
# 1. 复制此文件为 .env（在项目根目录）：cp .env.example .env
# 2. 修改下面的路径为你自己的 Obsidian vault 路径
# 3. .env 文件必须存在，否则 config.py 验证会失败
# ═══════════════════════════════════════════════════════════════════════════════

# ── 长桥 API（可选，不填则自动 fallback Yahoo Finance）──
LONGBRIDGE_APP_KEY=your_app_key
LONGBRIDGE_APP_SECRET=your_app_secret
LONGBRIDGE_ACCESS_TOKEN=your_access_token

# ── 搜索 API（可选，不配则使用 Yahoo Finance 免费搜索）──
# SERPAPI_KEY=your_serpapi_key

# ── Obsidian Vault 根目录 ──
# Vault 根目录路径
WIKI_BASE_DIR=/Users/al/Library/CloudStorage/Dropbox/应用/remotely-save/Lzw

# ── 项目相关子目录（在 Trader/ 下）──
WIKI_SUBDIR=Trader/Analysis
MATERIALS_SUBDIR=Trader/Materials

# ── Obsidian 通用目录（在 Vault 根目录下）──
OBSIDIAN_INBOX_DIR=/Users/al/Library/CloudStorage/Dropbox/应用/remotely-save/Lzw/Inbox
OBSIDIAN_TASKS_DIR=/Users/al/Library/CloudStorage/Dropbox/应用/remotely-save/Lzw/Tasks
OBSIDIAN_DASHBOARD_PATH=/Users/al/Library/CloudStorage/Dropbox/应用/remotely-save/Lzw/Dashboard.md

# ── 超时保护 ──
ANALYSIS_TIMEOUT=30

# ── 定时任务调度配置 ──
# 使用 launchd 时，这些值不需要（launchd 自己控制调度）
# 使用 scheduler.py 守护进程时，以下配置生效：
# SCHEDULE_SCAN_INBOX=*/30 * * * *
# SCHEDULE_REVIEW=0 9 * * *
# SCHEDULE_DASHBOARD=0 8 * * *
# SCHEDULE_NOTIFY=true
