# ── 长桥 API（可选，不填则自动 fallback Yahoo Finance）──
LONGBRIDGE_APP_KEY=your_app_key
LONGBRIDGE_APP_SECRET=your_app_secret
LONGBRIDGE_ACCESS_TOKEN=your_access_token

# ── 搜索 API（可选，不配则使用 DuckDuckGo 免费搜索）──
# SERPAPI_KEY=your_serpapi_key

# ── Obsidian Vault 路径映射 ──
WIKI_BASE_DIR=C:/Users/YourName/Documents/obsidian/YourVault
WIKI_SUBDIR=Analysis
MATERIALS_SUBDIR=Materials

# ── Obsidian 具体目录 ──
OBSIDIAN_INBOX_DIR=C:/Users/YourName/Documents/obsidian/YourVault/Inbox
OBSIDIAN_TASKS_DIR=C:/Users/YourName/Documents/obsidian/YourVault/Tasks
OBSIDIAN_DASHBOARD_PATH=C:/Users/YourName/Documents/obsidian/YourVault/Dashboard.md

# ── 超时保护 ──
ANALYSIS_TIMEOUT=30

# ── 定时任务调度配置 ──
# 使用 launchd 时，这些值不需要（launchd 自己控制调度）
# 使用 scheduler.py 守护进程时，以下配置生效：
# SCHEDULE_SCAN_INBOX=*/30 * * * *
# SCHEDULE_REVIEW=0 9 * * *
# SCHEDULE_DASHBOARD=0 8 * * *
# SCHEDULE_NOTIFY=true
